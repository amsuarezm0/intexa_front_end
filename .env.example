# VITE_API_BASE_URL: Base URL for the backend API.
# Leave unset in local dev — Vite proxies /api to localhost:8080 automatically.
# Set this at build time for production deployments.
# Example: VITE_API_BASE_URL="https://api.yourapp.com/api/v1"
VITE_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Microsoft Entra ID (Azure AD) — required for "Continuar con Microsoft" SSO.
# Create an App Registration in the Azure portal and set the redirect URI to your APP_URL.
# VITE_AZURE_CLIENT_ID: Application (client) ID of the Azure App Registration.
# VITE_AZURE_TENANT_ID: Directory (tenant) ID, or "common" for multi-tenant / personal accounts.
VITE_AZURE_CLIENT_ID=""
VITE_AZURE_TENANT_ID="common"
