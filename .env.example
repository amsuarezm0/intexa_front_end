# Backend API base URL. Leave unset in local dev — Vite proxies /api to localhost:8080.
# In production set this to the Render service URL.
VITE_API_BASE_URL=https://your-api.onrender.com/api/v1

# Microsoft Entra ID (Azure AD) — required for "Continuar con Microsoft" SSO.
VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_TENANT_ID=your-azure-tenant-id

# Public website domain used for nav links on the login page.
VITE_COMPANY_DOMAIN=https://www.grupointexa.co
